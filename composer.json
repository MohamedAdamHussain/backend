{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10.1",
        "nwidart/laravel-modules": "^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest-plugin-laravel": "^3.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\HR\\": "Modules/HR/app/",
            "Modules\\HR\\Database\\Factories\\": "Modules/HR/Database/Factories/",
            "Modules\\HR\\Database\\Seeders\\": "Modules/HR/Database/seeders/",
            "Modules\\Inventory\\": "Modules/Inventory/app/",
            "Modules\\Inventory\\Database\\Factories\\": "Modules/Inventory/Database/Factories/",
            "Modules\\Inventory\\Database\\Seeders\\": "Modules/Inventory/Database/seeders/",
            "Modules\\Auth\\": "Modules/Auth/app/",
            "Modules\\Auth\\Database\\Factories\\": "Modules/Auth/Database/Factories/",
            "Modules\\Auth\\Database\\Seeders\\": "Modules/Auth/Database/seeders/",
            "Modules\\Sales\\": "Modules/Sales/app/",
            "Modules\\Sales\\Database\\Factories\\": "Modules/Sales/Database/Factories/",
            "Modules\\Sales\\Database\\Seeders\\": "Modules/Sales/Database/seeders/",
            "Modules\\Accounts\\": "Modules/Accounts/app/",
            "Modules\\Accounts\\Database\\Factories\\": "Modules/Accounts/Database/Factories/",
            "Modules\\Accounts\\Database\\Seeders\\": "Modules/Accounts/Database/Seeders/",
            "Modules\\Shared\\": "Modules/Shared/app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
